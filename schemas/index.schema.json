{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/MarkEdit-app/extensions/raw/refs/heads/main/schemas/index.schema.json",
  "title": "MarkEdit Extension Registry Index",
  "description": "Generated feed the app and tools read. Do not edit by hand.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "extensions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "name",
          "description",
          "author",
          "homepage",
          "latest"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Unique identifier; equals the source filename."
          },
          "category": {
            "type": "string",
            "enum": ["extension", "theme"],
            "description": "Entry kind. Themes only customize the editor's appearance."
          },
          "name": {
            "type": "string",
            "description": "Human-readable name."
          },
          "description": {
            "type": "string",
            "description": "One-line summary."
          },
          "author": {
            "type": "string",
            "description": "Author name or handle."
          },
          "homepage": {
            "type": "string",
            "format": "uri",
            "description": "Project homepage."
          },
          "colorScheme": {
            "type": "string",
            "enum": ["light", "dark", "both"],
            "description": "Color scheme a theme supports. Present for themes."
          },
          "screenshots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            "description": "Screenshot URLs. Present for themes."
          },
          "latest": {
            "type": "object",
            "additionalProperties": false,
            "description": "The newest build the app should install. Full history stays in the source entry.",
            "required": [
              "version",
              "url",
              "sha256"
            ],
            "properties": {
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$",
                "description": "Resolved newest version, e.g. \"1.2.0\"."
              },
              "url": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://",
                "description": "HTTPS URL of the injectable .js (the file the editor injects)."
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$",
                "description": "SHA-256 of the file at url."
              },
              "minAppVersion": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$",
                "description": "Minimum MarkEdit version. Defaults to 1.0.0."
              },
              "notes": {
                "type": "string",
                "description": "Short release notes."
              }
            }
          }
        },
        "if": {
          "properties": {
            "category": {
              "const": "theme"
            }
          }
        },
        "then": {
          "required": ["colorScheme", "screenshots"]
        }
      }
    }
  }
}
